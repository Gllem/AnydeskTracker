@page
@model IndexModel
@inject UserManager<AppUser> UserManager
@{
    Layout = "_Layout";

    var user = await UserManager.GetUserAsync(User);

    ViewData["Title"] = user?.UserName;
}

<h3>@ViewData["Title"]</h3>
<div class="row">
    <div class="col-md-6">
        @if (user?.TelegramChatId != 0 && !string.IsNullOrEmpty(user?.TelegramUserName))
        {
            <div class="form-floating mb-3">
                <span class="form-control bg-light" placeholder="" value="">@user.TelegramUserName</span>
                <label class="form-label">Telegram Username</label>
            </div>
        }
        <a class="btn btn-success p-3" target="_blank" rel="noopener noreferrer" href="https://t.me/CarrothoodAnydeskTrackerBot?start=@user?.Id">
            Подключить ТГ бота
        </a>
        @if (user?.TelegramChatId != 0)
        {
            <button class="btn btn-secondary p-3" onclick="TestBot()">
                Протестировать бота
            </button>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        async function TestBot(){
            await fetch('/api/telegram/test', {
                method: 'POST'
            });
        }
    </script>
}